import json

def salva_dati_reali(prezzo, segnale, affidabilita, ultime_news):
    dati = {
        "status": "OPERATIVO",
        "price": prezzo,
        "signal": segnale,
        "reliability": affidabilita,
        "last_update": "11:11:13",
        "ticker": f"BTC/EUR: {prezzo} • SIGNAL: {segnale} • ",
        "news": ultime_news  # <--- QUESTO DEVE ESSERE UN ARRAY DI OGGETTI
    }
    with open('market_status.json', 'w') as f:
        json.dump(dati, f, indent=4)

